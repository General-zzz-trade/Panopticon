{
  "name": "agent-orchestrator",
  "version": "1.0.0",
  "private": true,
  "description": "Agent-Orchestrator: a TypeScript agent orchestrator for UI task planning, execution, replanning, and run inspection.",
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "sample:app": "tsx src/sample-app/server.ts",
    "benchmark:planner": "tsx src/planner/benchmark.ts",
    "inspect:run": "tsx src/inspect-run.ts",
    "test": "tsx --test src/**/*.test.ts",
    "test:e2e": "tsx --test src/e2e.integration.test.ts",
    "test:smoke": "tsx --test src/planner.smoke.test.ts src/replanner.smoke.test.ts src/diagnoser.smoke.test.ts",
    "regression": "npm run test:e2e && npm run benchmark:planner",
    "install:browsers": "playwright install chromium"
  },
  "dependencies": {
    "playwright": "^1.54.2"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
