{
  "name": "agent-orchestrator",
  "version": "1.0.0",
  "private": true,
  "description": "Agent-Orchestrator: a TypeScript agent orchestrator for UI task planning, execution, replanning, and run inspection.",
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "node --import tsx src/cli.ts",
    "sample:app": "node --import tsx src/sample-app/server.ts",
    "benchmark": "node --import tsx src/benchmarks/runner.ts",
    "benchmark:planner": "node --import tsx src/planner/benchmark.ts",
    "inspect:run": "node --import tsx src/inspect-run.ts",
    "verify:moonshot": "node --import tsx src/verify-moonshot.ts",
    "verify:moonshot:env": "node --env-file=.env.moonshot --import tsx src/verify-moonshot.ts",
    "test": "npm run test:unit:planner && npm run test:unit:shell && npm run test:smoke",
    "test:e2e": "node --import tsx --test src/e2e.integration.test.ts",
    "test:smoke": "node --import tsx --test src/planner.provider.smoke.test.ts src/replanner.provider.smoke.test.ts src/diagnoser.provider.smoke.test.ts",
    "test:smoke:planner": "node --import tsx --test src/planner.provider.smoke.test.ts",
    "test:smoke:replanner": "node --import tsx --test src/replanner.provider.smoke.test.ts",
    "test:smoke:diagnoser": "node --import tsx --test src/diagnoser.provider.smoke.test.ts",
    "test:unit:planner": "node --import tsx src/planner.test.ts",
    "test:unit:shell": "node --import tsx src/shell.test.ts",
    "regression": "npm run test:e2e && npm run benchmark:planner",
    "install:browsers": "playwright install chromium",
    "api": "node --import tsx src/api/server.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "better-sqlite3": "^12.8.0",
    "fastify": "^5.8.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.54.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.6.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
